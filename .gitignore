# AlgoTrade .gitignore

# Secrets — NEVER commit
.env
.env.local
.env.*.local
data/dhan_token.json

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
venv/
.venv/
env/

# Node — ALL locations
node_modules/
**/node_modules/
app/frontend/dist/
app/frontend/.vite/

# Algo JS junk — should never exist
algo/package.json
algo/package-lock.json
algo/node_modules/

# Stale root-level files
Vite.config
app/frontend/App.jsx

# Docker
*.tar

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Data files (sensitive — mount at runtime)
data/*.xls
data/*.xlsx

# Bhavcopy cache (large — download on first run)
data/bhavcopy_cache/

# Logs
logs/
*.log
data/trade_logs/

# Coverage
.coverage
htmlcov/
