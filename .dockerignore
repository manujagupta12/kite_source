# Docker ignore — AlgoTrade
# Prevents node_modules, __pycache__, secrets from entering image layers

# Git
.git/
.github/

# Node artefacts
node_modules/
**/node_modules/
algo/node_modules/
app/frontend/dist/
app/frontend/.vite/

# Python bytecode — explicit at every level to avoid BuildKit glob bugs
__pycache__/
**/__pycache__/
algo/__pycache__/
app/**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
.venv/
env/

# Secrets and data
.env
.env.*
data/

# Docs and logs
*.md
*.log
logs/
.DS_Store
Thumbs.db

# Algo junk
algo/package.json
algo/package-lock.json
