# AlgoTrade — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git (already in .gitignore)

# ── Backend Security ───────────────────────────────────────────
SECRET_KEY=algotrade-dev-secret-CHANGE-IN-PROD

# ── Server Ports ──────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Frontend (Vite) ───────────────────────────────────────────
# Leave blank for local dev (Vite proxy handles it)
# Set for remote/cloud deployment
VITE_API_URL=
VITE_WS_URL=

# ── Dhan API — optional, enables sub-second WebSocket ticks ───
# Get from: web.dhan.co > Profile > DhanHQ Trading APIs > Access Tokens
# Free with any Dhan trading account. No daily re-login needed.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ── Dhan TOTP auto-refresh — optional, for unattended operation ─
# Only needed if you want the token to refresh automatically.
# DHAN_PIN=your_4_digit_pin
# DHAN_TOTP_SECRET=BASE32SECRET_FROM_YOUR_2FA_APP

# ── REMOVED (no longer needed) ────────────────────────────────
# MULTITRADE_XLS_PATH — XLS feed retired, now using NSE Direct API
